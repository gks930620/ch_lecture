# ============================================
# ch_lecture 루트 .gitignore
# ============================================
# 이 파일 하나로 모든 하위 프로젝트에 적용됩니다.
# (하위 프로젝트의 .gitignore는 추가로 병합됩니다)

# =============================================
# 🔴 민감 정보 (절대 올리면 안 되는 파일)
# =============================================
# .env 파일 — API Key, OAuth Secret, JWT Secret 등 포함
.env
.env.*
!.env.example

# =============================================
# === IDE ===
# =============================================
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*~
.nb-gradle/

# =============================================
# === OS ===
# =============================================
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# =============================================
# === Java / Gradle 빌드 출력 ===
# =============================================
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar
build/
out/
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# Gradle
.gradle/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# =============================================
# === 빌드 로그 파일 (프로젝트 루트의 txt 로그) ===
# =============================================
build_err.txt
build_output.txt
build_result.txt

# =============================================
# === Log ===
# =============================================
*.log
logs/

# =============================================
# === Spring Boot / STS / Eclipse ===
# =============================================
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# =============================================
# === Node (JavaScript 프로젝트) ===
# =============================================
node_modules/

# =============================================
# === 업로드 파일 (서버 업로드 폴더) ===
# =============================================
uploads/

# =============================================
# === Apache Tomcat (다운로드 바이너리) ===
# =============================================
# 647개 파일 — 다운받은 바이너리는 GitHub에 올리지 않는 게 관례
apache-tomcat-*/

# =============================================
# === 기타 ===
# =============================================
hs_err_pid*
replay_pid*
*.ctxt
.mtj.tmp/

