<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- ============================================================ -->
    <!-- [Ch00 실습환경] 기본 설정                                      -->
    <!-- 프로젝트 생성 시 기본으로 작성                                  -->
    <!-- ============================================================ -->
    <display-name>Web Basic Lecture</display-name>

    <!-- 기본 시작 페이지 설정 -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ============================================================ -->
    <!-- [Ch04 Forward/Redirect] 서블릿 매핑 참고                       -->
    <!-- 이 프로젝트에서는 @WebServlet 어노테이션으로 매핑하고 있음       -->
    <!-- 아래는 web.xml로 매핑할 경우의 예시 (현재 주석 처리)            -->
    <!-- ============================================================ -->
    <!--
    <servlet>
        <servlet-name>ForwardRedirectServlet</servlet-name>
        <servlet-class>com.example.chlecture.forwardredirect.ForwardRedirectServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ForwardRedirectServlet</servlet-name>
        <url-pattern>/04_forward_redirect/handle</url-pattern>
    </servlet-mapping>
    -->

    <!-- ============================================================ -->
    <!-- [Ch05 Cookie/Session] 서블릿 매핑 참고                         -->
    <!-- @WebServlet 어노테이션 사용 중 (web.xml 예시는 주석)           -->
    <!-- ============================================================ -->
    <!--
    <servlet>
        <servlet-name>CookieSessionServlet</servlet-name>
        <servlet-class>com.example.chlecture.cookiesession.CookieSessionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CookieSessionServlet</servlet-name>
        <url-pattern>/05_cookie_session/cookie</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CookieSessionServlet</servlet-name>
        <url-pattern>/05_cookie_session/session</url-pattern>
    </servlet-mapping>
    -->

    <!-- ============================================================ -->
    <!-- [Ch06 WEB-INF] 서블릿 매핑 참고                                -->
    <!-- WEB-INF 내부 JSP를 forward로 제공하는 서블릿                    -->
    <!-- @WebServlet 어노테이션 사용 중                                 -->
    <!-- ============================================================ -->
    <!--
    <servlet>
        <servlet-name>WebInfForwardServlet</servlet-name>
        <servlet-class>com.example.chlecture.webinf.WebInfForwardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WebInfForwardServlet</servlet-name>
        <url-pattern>/06_WEB-INF/hidden</url-pattern>
    </servlet-mapping>
    -->

    <!-- ============================================================ -->
    <!-- [Ch07 에러 처리] 에러 페이지 매핑                               -->
    <!-- 특정 HTTP 상태 코드나 예외 발생 시 커스텀 에러 페이지로 이동     -->
    <!-- Ch07 수업 시 주석 해제하여 사용                                 -->
    <!-- ============================================================ -->
    <error-page>
        <error-code>404</error-code>
        <location>/07_error_handling/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/07_error_handling/error/500.jsp</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Throwable</exception-type>
        <location>/07_error_handling/error/500.jsp</location>
    </error-page>

    <!-- ============================================================ -->
    <!-- [Ch09 Filter] 필터 매핑 참고                                   -->
    <!-- @WebFilter 어노테이션 사용 중 (web.xml 예시는 주석)            -->
    <!-- 아래는 web.xml로 필터를 등록할 경우의 예시                      -->
    <!-- ============================================================ -->
    <!--
    <filter>
        <filter-name>LoggingFilter</filter-name>
        <filter-class>com.example.chlecture.filter.LoggingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>LoggingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    -->

    <!-- ============================================================ -->
    <!-- [Ch09 Filter] UTF-8 인코딩 필터 (직접 구현 대안)               -->
    <!-- 한글 깨짐 방지를 위해 모든 요청에 UTF-8 인코딩 적용            -->
    <!-- 실제 운영에서는 별도 EncodingFilter 클래스를 만들어 등록        -->
    <!-- ============================================================ -->
    <!--
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.example.chlecture.filter.EncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    -->

    <!-- ============================================================ -->
    <!-- [Ch10 MyBatis 게시판] 게시판 컨트롤러 서블릿 참고               -->
    <!-- @WebServlet("/board/*") 어노테이션 사용 중                     -->
    <!-- ============================================================ -->
    <!--
    <servlet>
        <servlet-name>BoardController</servlet-name>
        <servlet-class>com.example.chlecture.board.controller.BoardController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BoardController</servlet-name>
        <url-pattern>/board/*</url-pattern>
    </servlet-mapping>
    -->

    <!-- ============================================================ -->
    <!-- [Ch13 Listener] 리스너 등록 참고                               -->
    <!-- @WebListener 어노테이션 사용 중 (web.xml 예시는 주석)          -->
    <!-- 아래는 web.xml로 리스너를 등록할 경우의 예시                    -->
    <!-- ============================================================ -->
    <!--
    <listener>
        <listener-class>com.example.chlecture.listener.AppInitListener</listener-class>
    </listener>
    <listener>
        <listener-class>com.example.chlecture.listener.SessionCountListener</listener-class>
    </listener>
    -->

</web-app>

